<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OmsiStudio.App.ViewModels"
        xmlns:models="using:OmsiStudio.Core.Assets"
        xmlns:views="using:OmsiStudio.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="OmsiStudio.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding L[AppTitle]}"
        Background="#121214"
        Foreground="#e2e8f0">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="320,*">
        <!-- Sidebar Panel -->
        <Border Grid.Column="0" Background="#1a1a1e" BorderBrush="#2a2a32" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" Margin="16">
                <!-- Header Title & Language Selector -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                    <TextBlock Grid.Column="0" Text="OMSI Studio" FontSize="20" FontWeight="Bold" Foreground="#6366f1" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                        <Button Content="TR" 
                                Command="{Binding SetCultureCommand}" 
                                CommandParameter="tr-TR"
                                FontSize="9"
                                Padding="6,2"
                                FontWeight="Bold"
                                Background="{Binding TurkishButtonBackground}"
                                Foreground="#ffffff"
                                BorderThickness="0"
                                CornerRadius="3"/>
                        <Button Content="EN" 
                                Command="{Binding SetCultureCommand}" 
                                CommandParameter="en-US"
                                FontSize="9"
                                Padding="6,2"
                                FontWeight="Bold"
                                Background="{Binding EnglishButtonBackground}"
                                Foreground="#ffffff"
                                BorderThickness="0"
                                CornerRadius="3"/>
                    </StackPanel>
                </Grid>
                <TextBlock Grid.Row="1" Text="{Binding L[AppTitle]}" FontSize="12" Foreground="#94a3b8" Margin="0,0,0,16"/>

                <!-- Root Selection Button & Info -->
                <StackPanel Grid.Row="2" Margin="0,0,0,16" Spacing="6">
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <Button Grid.Column="0"
                                Command="{Binding SelectFolderCommand}" 
                                HorizontalAlignment="Stretch" 
                                HorizontalContentAlignment="Center" 
                                Background="#6366f1" 
                                Foreground="White" 
                                CornerRadius="6" 
                                Padding="0,10">
                            <TextBlock Text="{Binding L[SelectRootFolder]}" FontWeight="SemiBold"/>
                        </Button>
                        <Button Grid.Column="1"
                                Command="{Binding RefreshScanCommand}" 
                                ToolTip.Tip="{Binding L[RefreshScan]}"
                                Margin="6,0,0,0"
                                Width="36"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="#1e293b" 
                                Foreground="White" 
                                CornerRadius="6">
                            <TextBlock Text="🔄" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Grid.Column="2"
                                Command="{Binding ClearCacheAndRefreshCommand}" 
                                ToolTip.Tip="{Binding L[ClearCacheAndRescan]}"
                                Margin="6,0,0,0"
                                Width="36"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Background="#1e293b" 
                                Foreground="White" 
                                CornerRadius="6">
                            <TextBlock Text="🗑️" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                    </Grid>
                    <TextBlock Text="{Binding RootDirectoryDisplay}" 
                               FontSize="11" 
                               Foreground="#64748b" 
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Search Input -->
                <TextBox Grid.Row="3" 
                         Text="{Binding SearchText, Mode=TwoWay}" 
                         PlaceholderText="{Binding L[SearchPlaceholder]}" 
                         CornerRadius="6" 
                         Margin="0,0,0,12"
                         IsEnabled="{Binding HasAssets}"/>

                <!-- Grouping Selector -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="16" Margin="0,0,0,12" IsEnabled="{Binding HasAssets}">
                    <RadioButton Content="{Binding L[GroupingFolder]}" 
                                 IsChecked="{Binding IsFolderGrouping, Mode=TwoWay}"
                                 GroupName="GroupingModeGroup" FontSize="12" Foreground="#94a3b8"/>
                    <RadioButton Content="{Binding L[GroupingCategory]}" 
                                 IsChecked="{Binding IsCategoryGrouping, Mode=TwoWay}"
                                 GroupName="GroupingModeGroup" FontSize="12" Foreground="#94a3b8"/>
                </StackPanel>

                <!-- Asset List -->
                <Grid Grid.Row="5" RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" 
                               Text="{Binding AssetCountDisplay}" 
                               FontSize="11" 
                               FontWeight="SemiBold" 
                               Foreground="#94a3b8"
                               Margin="2,0,0,6"/>
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding AssetGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:AssetGroupViewModel">
                                    <StackPanel Margin="0,0,0,12">
                                        <!-- Group Header with Count -->
                                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="2,0,0,6">
                                            <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="#6366f1"/>
                                            <TextBlock Text="{Binding Assets.Count, StringFormat='({0})'}" FontSize="12" Foreground="#64748b"/>
                                        </StackPanel>
                                        <!-- Nested ListBox for Assets in this group -->
                                        <ListBox ItemsSource="{Binding Assets}" 
                                                 SelectedItem="{Binding $parent[Window].DataContext.SelectedAsset, Mode=OneWay}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 CornerRadius="6">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate DataType="models:OmsiAsset">
                                                    <Button Command="{Binding $parent[Window].DataContext.SelectAssetCommand}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Left"
                                                            Padding="8,6">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="{Binding DisplayName}" 
                                                                        FontSize="13" 
                                                                        FontWeight="Medium" 
                                                                        Foreground="#f8fafc"
                                                                        TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding RelativePath}" 
                                                                        FontSize="11" 
                                                                        Foreground="#64748b" 
                                                                        TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- Main Details / Status Panel -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <StackPanel Grid.Row="0">
                <!-- Scan Status Bar (Warnings/Errors Summary) -->
                <Border Background="#1a1215" BorderBrush="#ef4444" BorderThickness="0,0,0,1" Padding="16,8" IsVisible="{Binding ShowTopScanSummary}">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding HasScanErrors}">
                                <TextBlock Text="❌" Foreground="#fca5a5" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ScanErrorsDisplay}" Foreground="#fca5a5" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6" IsVisible="{Binding HasScanWarnings}">
                                <TextBlock Text="⚠️" Foreground="#fcd34d" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ScanWarningsDisplay}" Foreground="#fcd34d" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding L[ScanCompletedMessages]}" Foreground="#94a3b8" FontSize="11" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <Grid Grid.Row="1">
                <!-- 1. Error State View -->
                <Grid VerticalAlignment="Center" HorizontalAlignment="Center" IsVisible="{Binding HasError}">
                    <Border Background="#2a1215" BorderBrush="#ef4444" BorderThickness="1" CornerRadius="8" Padding="20" Width="400">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding L[ErrorTitle]}" FontWeight="Bold" Foreground="#ef4444" FontSize="16"/>
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#fca5a5" TextWrapping="Wrap" FontSize="13"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 2. Welcome / Empty Directory State View -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" 
                            IsVisible="{Binding IsEmptyState}">
                    <TextBlock Text="{Binding L[WelcomeTitle]}" FontSize="22" FontWeight="Bold" Foreground="#f8fafc" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding L[WelcomeMessage]}" 
                               Foreground="#94a3b8" 
                               HorizontalAlignment="Center" 
                               TextAlignment="Center" 
                               MaxWidth="400" 
                               TextWrapping="Wrap"
                               FontSize="13"/>
                </StackPanel>

                <!-- 3. Asset details selected (Main View) -->
                <ScrollViewer IsVisible="{Binding HasSelectedAsset}">
                    <StackPanel Margin="24" Spacing="20">
                        <!-- Title Banner Card -->
                        <Border Background="#1e1e24" BorderBrush="#2a2a32" BorderThickness="1" CornerRadius="8" Padding="20">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding SelectedAssetDisplayName}" 
                                           FontSize="24" 
                                           FontWeight="Bold" 
                                           Foreground="#ffffff"
                                           Margin="0,0,0,8"/>
                                
                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="{Binding L[RelativePathLabel]}" FontSize="13" Foreground="#94a3b8"/>
                                    <TextBlock Text=": " FontSize="13" Foreground="#94a3b8"/>
                                    <TextBlock Text="{Binding SelectedAsset.RelativePath}" FontSize="13" Foreground="#e2e8f0"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="{Binding L[FullPathLabel]}" FontSize="11" Foreground="#64748b"/>
                                    <TextBlock Text=": " FontSize="11" Foreground="#64748b"/>
                                    <TextBlock Text="{Binding SelectedAsset.SourceScoPath}" FontSize="11" Foreground="#94a3b8" TextWrapping="Wrap"/>
                                </StackPanel>

                                <!-- Copy & Open File Actions -->
                                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                                            Orientation="Horizontal" Spacing="8">
                                    <Button Content="{Binding L[CopyFullPath]}" 
                                            Command="{Binding CopyAssetPathCommand}"
                                            FontSize="12"
                                            Padding="12,6"
                                            Background="#312e81"
                                            Foreground="#e0e7ff"
                                            BorderThickness="0"
                                            CornerRadius="4"/>
                                    <Button Content="{Binding L[CopyRelativePath]}" 
                                            Command="{Binding CopyRelativePathCommand}"
                                            FontSize="12"
                                            Padding="12,6"
                                            Background="#1e293b"
                                            Foreground="#cbd5e1"
                                            BorderThickness="0"
                                            CornerRadius="4"/>
                                    <Button Content="{Binding L[OpenFolder]}" 
                                            Command="{Binding OpenAssetFolderCommand}"
                                            FontSize="12"
                                            Padding="12,6"
                                            Background="#065f46"
                                            Foreground="#d1fae5"
                                            BorderThickness="0"
                                            CornerRadius="4"/>
                                    <Button Content="{Binding L[ExportManifest]}" 
                                            Command="{Binding ExportManifestCommand}"
                                            FontSize="12"
                                            Padding="12,6"
                                            Background="#701a75"
                                            Foreground="#fdf4ff"
                                            BorderThickness="0"
                                            CornerRadius="4"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Export Success Card -->
                        <Border IsVisible="{Binding HasExportSuccess}"
                                Background="#064e3b"
                                BorderBrush="#047857"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16,10">
                            <TextBlock Text="{Binding ExportSuccessMessage}"
                                       Foreground="#a7f3d0"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Export Error Card -->
                        <Border IsVisible="{Binding HasExportError}"
                                Background="#7f1d1d"
                                BorderBrush="#b91c1c"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16,10">
                            <TextBlock Text="{Binding ExportErrorMessage}"
                                       Foreground="#fecaca"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Preview Panel -->
                        <Border Background="#1a1a1e" BorderBrush="#2a2a32" BorderThickness="1" CornerRadius="8" Padding="16" IsVisible="{Binding HasSelectedPreviewModelReference}">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto,Auto">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding L[PreviewPanelTitle]}" FontSize="14" FontWeight="SemiBold" Foreground="#6366f1"/>
                                        <TextBlock Text=":" FontSize="14" Foreground="#64748b"/>
                                        <TextBlock Text="{Binding PreviewModelDisplayName}" FontSize="13" Foreground="#e2e8f0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    
                                    <Border Grid.Column="1" Background="#1e293b" BorderBrush="#334155" BorderThickness="1" CornerRadius="4" Padding="6,2" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding PreviewStatusText}" FontSize="11" FontWeight="SemiBold" Foreground="#94a3b8"/>
                                    </Border>
                                    
                                    <Button Grid.Column="2" 
                                            Content="{Binding L[CancelPreview]}" 
                                            Command="{Binding CancelPreviewCommand}" 
                                            IsVisible="{Binding IsPreviewLoading}"
                                            FontSize="11"
                                            Padding="10,4"
                                            Background="#991b1b"
                                            Foreground="#fee2e2"
                                            CornerRadius="4"
                                            VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Viewport Area -->
                                <Border MinHeight="420" Background="#09090b" BorderBrush="#2a2a32" BorderThickness="1" CornerRadius="6">
                                    <Grid>
                                        <!-- HasPreview is false -->
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" IsVisible="{Binding !HasPreview}">
                                            <TextBlock Text="📐" FontSize="24" HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding L[PreviewPanelPlaceholder]}" 
                                                       Foreground="#64748b" 
                                                       FontSize="12" 
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="280"/>
                                        </StackPanel>
                                        
                                        <!-- HasPreview is true -->
                                        <Grid IsVisible="{Binding HasPreview}">
                                            <!-- Software Wireframe Viewport Control (Default) -->
                                            <views:SoftwareWireframeViewportControl x:Name="SoftwareViewport" 
                                                                                    MeshData="{Binding PreviewResult.MeshData}"
                                                                                    CameraYaw="{Binding CameraYaw, Mode=TwoWay}"
                                                                                    CameraPitch="{Binding CameraPitch, Mode=TwoWay}"
                                                                                    CameraDistance="{Binding CameraDistance, Mode=TwoWay}"
                                                                                    ShowBoundingBox="{Binding ShowBoundingBox}"
                                                                                    VisualMode="{Binding VisualMode}"
                                                                                    TextureBindings="{Binding PreviewTextureBindings}"
                                                                                    IsVisible="{Binding !EnableExperimentalGlPreview}"/>

                                            <!-- OpenGL Viewport Container (Only if enabled) -->
                                            <Grid IsVisible="{Binding EnableExperimentalGlPreview}">
                                                <!-- OpenGL Viewport Control -->
                                                <views:O3dGlViewportControl x:Name="GlViewport" 
                                                                             RendererHost="{Binding RendererHost}"
                                                                             CameraYaw="{Binding CameraYaw, Mode=TwoWay}"
                                                                             CameraPitch="{Binding CameraPitch, Mode=TwoWay}"
                                                                             CameraDistance="{Binding CameraDistance, Mode=TwoWay}"
                                                                             RenderVersion="{Binding RenderVersion}"
                                                                             IsOpenGlInitialized="{Binding IsOpenGlInitialized, Mode=TwoWay}"
                                                                             IsRendererHostInitialized="{Binding IsRendererHostInitialized, Mode=TwoWay}"
                                                                             OpenGlRenderCallCount="{Binding OpenGlRenderCallCount, Mode=TwoWay}"
                                                                             LastViewportError="{Binding LastViewportError, Mode=TwoWay}"
                                                                             IsVisible="{Binding !#GlViewport.HasError}"/>
                                                
                                                <!-- GL Error Fallback UI -->
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8" IsVisible="{Binding #GlViewport.HasError}">
                                                    <TextBlock Text="⚠️" FontSize="24" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding L[PreviewViewportInitFailed]}" 
                                                               Foreground="#ef4444" 
                                                               FontSize="13" 
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding #GlViewport.ErrorMessage}" 
                                                               Foreground="#f87171" 
                                                               FontSize="11"
                                                               HorizontalAlignment="Center"
                                                               TextWrapping="Wrap"
                                                               TextAlignment="Center"
                                                               MaxWidth="260"/>
                                                </StackPanel>
                                            </Grid>
                                            
                                            <!-- Camera Control UI Overlay (Hidden) -->
                                            <StackPanel Orientation="Horizontal" 
                                                         Spacing="6" 
                                                         HorizontalAlignment="Center" 
                                                         VerticalAlignment="Bottom" 
                                                         Margin="0,0,0,10"
                                                         IsVisible="False">
                                                <Button Content="◀" 
                                                        Command="{Binding OrbitYawLeftCommand}" 
                                                        ToolTip.Tip="{Binding L[CamYawLeft]}"
                                                        Width="32" Height="32" 
                                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                        Background="#1e293b" Foreground="#e2e8f0" CornerRadius="4"/>
                                                <Button Content="▶" 
                                                        Command="{Binding OrbitYawRightCommand}" 
                                                        ToolTip.Tip="{Binding L[CamYawRight]}"
                                                        Width="32" Height="32" 
                                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                        Background="#1e293b" Foreground="#e2e8f0" CornerRadius="4"/>
                                                <Button Content="▲" 
                                                        Command="{Binding OrbitPitchUpCommand}" 
                                                        ToolTip.Tip="{Binding L[CamPitchUp]}"
                                                        Width="32" Height="32" 
                                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                        Background="#1e293b" Foreground="#e2e8f0" CornerRadius="4"/>
                                                <Button Content="▼" 
                                                        Command="{Binding OrbitPitchDownCommand}" 
                                                        ToolTip.Tip="{Binding L[CamPitchDown]}"
                                                        Width="32" Height="32" 
                                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                        Background="#1e293b" Foreground="#e2e8f0" CornerRadius="4"/>
                                                <Button Content="➕" 
                                                        Command="{Binding ZoomInCommand}" 
                                                        ToolTip.Tip="{Binding L[CamZoomIn]}"
                                                        Width="32" Height="32" 
                                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                        Background="#1e293b" Foreground="#e2e8f0" CornerRadius="4"/>
                                                <Button Content="➖" 
                                                        Command="{Binding ZoomOutCommand}" 
                                                        ToolTip.Tip="{Binding L[CamZoomOut]}"
                                                        Width="32" Height="32" 
                                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                        Background="#1e293b" Foreground="#e2e8f0" CornerRadius="4"/>
                                                <Button Content="⟲" 
                                                        Command="{Binding ResetCameraCommand}" 
                                                        ToolTip.Tip="{Binding L[CamReset]}"
                                                        Width="32" Height="32" 
                                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                        Background="#4f46e5" Foreground="White" CornerRadius="4"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Summary details when HasPreview is true -->
                                <StackPanel Spacing="6" IsVisible="{Binding HasPreview}">
                                    <TextBlock Text="{Binding PreviewMeshSummaryText}" FontSize="12" Foreground="#e2e8f0"/>
                                    <TextBlock Text="{Binding PreviewBoundsSummary}" FontSize="12" Foreground="#94a3b8" IsVisible="{Binding HasPreviewBounds}"/>
                                    
                                    <!-- Visual Mode Selection -->
                                    <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                        <TextBlock Grid.Column="0" Text="{Binding L[VisualModeLabel]}" FontSize="11" Foreground="#94a3b8" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" SelectedIndex="{Binding VisualModeInt}" FontSize="11" Width="140" Height="26" Background="#1e293b" BorderBrush="#2a2a32">
                                            <ComboBoxItem Content="{Binding L[VisualModeWireframe]}"/>
                                            <ComboBoxItem Content="{Binding L[VisualModeSolid]}"/>
                                            <ComboBoxItem Content="{Binding L[VisualModeSolidWireframe]}"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Bounding Box Checkbox -->
                                    <CheckBox Content="{Binding L[ShowBoundingBox]}" IsChecked="{Binding ShowBoundingBox}" FontSize="11" Foreground="#94a3b8" Margin="0,4,0,0"/>

                                    <!-- Preview Materials Section -->
                                    <Border BorderBrush="#2a2a32" BorderThickness="0,1,0,0" Margin="0,8,0,0" Padding="0,8,0,0">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding L[PreviewMaterials]}" FontSize="11" FontWeight="SemiBold" Foreground="#e2e8f0"/>
                                            
                                            <!-- Render Debug Counters -->
                                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,4" IsVisible="{Binding !EnableExperimentalGlPreview}">
                                                <TextBlock Text="Debug:" FontSize="9" Foreground="#64748b"/>
                                                <TextBlock Text="Textured:" FontSize="9" Foreground="#64748b"/>
                                                <TextBlock Text="{Binding #SoftwareViewport.LastTexturedTriangleCount}" FontSize="9" Foreground="#4ade80" FontWeight="SemiBold"/>
                                                <TextBlock Text="Fallback:" FontSize="9" Foreground="#64748b"/>
                                                <TextBlock Text="{Binding #SoftwareViewport.LastFallbackTriangleCount}" FontSize="9" Foreground="#f87171" FontWeight="SemiBold"/>
                                                <TextBlock Text="Total:" FontSize="9" Foreground="#64748b"/>
                                                <TextBlock Text="{Binding #SoftwareViewport.LastRenderedTriangleCount}" FontSize="9" Foreground="#94a3b8"/>
                                            </StackPanel>
                                            
                                            <!-- If no materials -->
                                            <TextBlock Text="{Binding L[NoPreviewMaterials]}" FontSize="10" Foreground="#64748b" IsVisible="{Binding !HasPreviewMaterials}" Margin="0,2,0,0"/>
                                            
                                            <!-- Items of materials -->
                                            <ItemsControl ItemsSource="{Binding PreviewMaterials}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,4,0,4">
                                                            <Grid ColumnDefinitions="Auto,Auto,*,Auto" Margin="0,0,0,2">
                                                                <!-- Color Swatch -->
                                                                <Border Grid.Column="0" Width="12" Height="12" CornerRadius="2" Background="{Binding ColorBrush}" BorderBrush="#3f3f46" BorderThickness="1" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                
                                                                <!-- Thumbnail image if texture is bound -->
                                                                <Border Grid.Column="1" Width="14" Height="14" CornerRadius="2" ClipToBounds="True" Background="#111115" BorderBrush="#3f3f46" BorderThickness="1" VerticalAlignment="Center" Margin="0,0,6,0" IsVisible="{Binding HasTextureThumbnail}">
                                                                    <Image Source="{Binding TextureThumbnail}" Stretch="UniformToFill"/>
                                                                </Border>

                                                                <!-- Material Name -->
                                                                <TextBlock Grid.Column="2" Text="{Binding MaterialName}" FontSize="10" FontWeight="Medium" Foreground="#cbd5e1" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                                 
                                                                <!-- Binding Status & Image Size if Bound -->
                                                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="8,0,0,0">
                                                                    <TextBlock Text="{Binding BindingStatus}" FontSize="9" Foreground="{Binding StatusForeground}" FontWeight="SemiBold"/>
                                                                    <TextBlock Text="{Binding ImageSizeText}" FontSize="8" Foreground="#64748b" IsVisible="{Binding HasTextureThumbnail}"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <!-- Resolved Path display -->
                                                            <TextBlock Text="{Binding ResolvedPath}" FontSize="8" Foreground="#475569" TextTrimming="CharacterEllipsis" Margin="18,0,0,1" IsVisible="{Binding HasResolvedPath}"/>

                                                            <!-- Diagnostics Warning/Error list display -->
                                                            <TextBlock Text="{Binding DiagnosticsText}" FontSize="8.5" Foreground="#f87171" TextWrapping="Wrap" Margin="18,1,0,0" IsVisible="{Binding HasDiagnostics}"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <!-- Experimental OpenGL Preview -->
                                    <Expander Header="Experimental OpenGL Preview" IsExpanded="False" FontSize="11" Foreground="#94a3b8" Margin="0,4,0,0">
                                        <StackPanel Spacing="4" Margin="0,4,0,0">
                                            <CheckBox Content="Use OpenGL Viewport" IsChecked="{Binding EnableExperimentalGlPreview}" FontSize="11" Foreground="#e2e8f0"/>
                                            
                                            <StackPanel Spacing="2" IsVisible="{Binding EnableExperimentalGlPreview}" Margin="0,4,0,0">
                                                <CheckBox Content="Debug Triangle (Render Baseline)" IsChecked="{Binding DebugTriangleEnabled}" FontSize="11" Foreground="#94a3b8"/>
                                                
                                                <TextBlock Text="{Binding LastFrameDrawAttempted, StringFormat='Draw Attempted: {0}'}" FontSize="10" Foreground="#64748b"/>
                                                <TextBlock Text="{Binding LastFrameUploadedVertexCount, StringFormat='Uploaded Vertices: {0}'}" FontSize="10" Foreground="#64748b"/>
                                                <TextBlock Text="{Binding LastFrameUploadedIndexCount, StringFormat='Uploaded Indices: {0}'}" FontSize="10" Foreground="#64748b"/>
                                                <TextBlock Text="{Binding LastGlError, StringFormat='Last GL Error: {0}'}" FontSize="10" Foreground="#f87171"/>
                                                
                                                <!-- Viewport Render Loop Debug Info -->
                                                <TextBlock Text="{Binding IsOpenGlInitialized, StringFormat='GL Init: {0}'}" FontSize="10" Foreground="#64748b"/>
                                                <TextBlock Text="{Binding IsRendererHostInitialized, StringFormat='Host Init: {0}'}" FontSize="10" Foreground="#64748b"/>
                                                <TextBlock Text="{Binding OpenGlRenderCallCount, StringFormat='GL Render Call Count: {0}'}" FontSize="10" Foreground="#64748b"/>
                                                <TextBlock Text="{Binding LastViewportError, StringFormat='Viewport Error: {0}'}" FontSize="10" Foreground="#f87171" IsVisible="{Binding LastViewportError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                                <TextBlock Text="OpenGL render callback has not fired" FontSize="10" Foreground="#ef4444" FontWeight="SemiBold" IsVisible="{Binding !OpenGlRenderCallCount}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>

                                <!-- Diagnostics (Visible when HasPreviewDiagnostics is true) -->
                                <Border Background="{Binding PreviewDiagnosticsBackground}" BorderBrush="{Binding PreviewDiagnosticsBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10" IsVisible="{Binding HasPreviewDiagnostics}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{Binding L[O3dDiagnostics]}" FontSize="12" FontWeight="Bold" Foreground="{Binding PreviewDiagnosticsHeaderColor}"/>
                                        <ItemsControl ItemsSource="{Binding PreviewDiagnostics}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Message}" FontSize="11" Foreground="{Binding $parent[Window].DataContext.PreviewDiagnosticsTextColor}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Description Card -->
                        <Border Background="#1a1a1e" BorderBrush="#2a2a32" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding L[DescriptionSection]}" FontSize="14" FontWeight="SemiBold" Foreground="#6366f1"/>
                                <TextBlock Text="{Binding SelectedAsset.Description}" 
                                           FontSize="13" 
                                           Foreground="#e2e8f0" 
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding SelectedAsset.Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <TextBlock Text="{Binding L[NoDescription]}" 
                                           FontSize="13" 
                                           FontStyle="Italic" 
                                           Foreground="#64748b"
                                           IsVisible="{Binding SelectedAsset.Description, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Groups (Badges) -->
                        <Border Background="#1a1a1e" BorderBrush="#2a2a32" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="{Binding L[GroupHierarchySection]}" FontSize="14" FontWeight="SemiBold" Foreground="#6366f1"/>
                                <ItemsControl ItemsSource="{Binding SelectedAsset.Groups}" IsVisible="{Binding SelectedAsset.HasGroups}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#312e81" BorderBrush="#4338ca" BorderThickness="1" CornerRadius="12" Padding="10,4" Margin="0,0,8,8">
                                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#e0e7ff" VerticalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding L[NoGrouping]}" 
                                           FontSize="13" 
                                           FontStyle="Italic" 
                                           Foreground="#64748b"
                                           IsVisible="{Binding SelectedAsset.HasNoGroups}"/>
                            </StackPanel>
                        </Border>

                        <!-- Meshes (.o3d references) -->
                        <Border Background="#1a1a1e" BorderBrush="#2a2a32" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="{Binding L[MeshesSection]}" FontSize="14" FontWeight="SemiBold" Foreground="#6366f1"/>
                                <ItemsControl ItemsSource="{Binding SelectedAsset.ModelReferences}" IsVisible="{Binding SelectedAsset.HasMeshes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#121214" BorderBrush="#2a2a32" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                                        <TextBlock Grid.Column="0" Text="📦" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding MeshPath}" FontSize="13" FontWeight="SemiBold" Foreground="#e2e8f0" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="2" 
                                                                Content="{Binding $parent[Window].DataContext.L[PreviewButton]}" 
                                                                Command="{Binding $parent[Window].DataContext.LoadPreviewCommand}" 
                                                                CommandParameter="{Binding}"
                                                                FontSize="11"
                                                                Padding="10,4"
                                                                Background="#4f46e5"
                                                                Foreground="White"
                                                                CornerRadius="4"
                                                                VerticalAlignment="Center"/>
                                                    </Grid>
                                                    
                                                    <!-- Metadata details when available -->
                                                    <StackPanel Margin="24,4,0,0" Spacing="6" IsVisible="{Binding HasMetadata}">
                                                        <Border Background="#1a1a1e" BorderBrush="#2e2e38" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,2,0,0">
                                                            <StackPanel Spacing="6">
                                                                <TextBlock Text="{Binding $parent[Window].DataContext.L[O3dMetadataTitle]}" FontSize="12" FontWeight="Bold" Foreground="#818cf8"/>
                                                                
                                                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,4,0,0">
                                                                    <!-- Version -->
                                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding $parent[Window].DataContext.L[O3dVersion]}" FontSize="11" Foreground="#94a3b8" Margin="0,0,12,3"/>
                                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Metadata.DisplayVersion}" FontSize="11" Foreground="#f8fafc" FontWeight="Medium" Margin="0,0,0,3"/>
                                                                    
                                                                    <!-- Encrypted -->
                                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding $parent[Window].DataContext.L[O3dEncrypted]}" FontSize="11" Foreground="#94a3b8" Margin="0,0,12,3"/>
                                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Metadata.IsEncrypted}" FontSize="11" Foreground="#f8fafc" FontWeight="Medium" Margin="0,0,0,3"/>
                                                                    
                                                                    <!-- Mesh Count -->
                                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding $parent[Window].DataContext.L[O3dMeshCount]}" FontSize="11" Foreground="#94a3b8" Margin="0,0,12,3"/>
                                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Metadata.MeshCount}" FontSize="11" Foreground="#f8fafc" FontWeight="Medium" Margin="0,0,0,3"/>
                                                                    
                                                                    <!-- Vertex Count -->
                                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding $parent[Window].DataContext.L[O3dVertexCount]}" FontSize="11" Foreground="#94a3b8" Margin="0,0,12,3"/>
                                                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Metadata.VertexCount}" FontSize="11" Foreground="#f8fafc" FontWeight="Medium" Margin="0,0,0,3"/>
                                                                    
                                                                    <!-- Triangle Count -->
                                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding $parent[Window].DataContext.L[O3dTriangleCount]}" FontSize="11" Foreground="#94a3b8" Margin="0,0,12,3"/>
                                                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Metadata.TriangleCount}" FontSize="11" Foreground="#f8fafc" FontWeight="Medium" Margin="0,0,0,3"/>
                                                                    
                                                                    <!-- Material Count -->
                                                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding $parent[Window].DataContext.L[O3dMaterialCount]}" FontSize="11" Foreground="#94a3b8" Margin="0,0,12,3"/>
                                                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Metadata.MaterialCount}" FontSize="11" Foreground="#f8fafc" FontWeight="Medium" Margin="0,0,0,3"/>
                                                                </Grid>
                                                                
                                                                <!-- Texture References -->
                                                                <StackPanel Margin="0,6,0,0" Spacing="3">
                                                                    <TextBlock Text="{Binding $parent[Window].DataContext.L[O3dTextureReferences]}" FontSize="11" FontWeight="Bold" Foreground="#94a3b8"/>
                                                                    <ItemsControl ItemsSource="{Binding Metadata.TextureReferences}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <TextBlock Text="{Binding Path}" FontSize="11" Foreground="#cbd5e1" Margin="8,0,0,1"/>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                    
                                                    <!-- No metadata available style fallback -->
                                                    <StackPanel Margin="24,2,0,0" Orientation="Horizontal" IsVisible="{Binding HasNoMetadata}">
                                                        <TextBlock Text="{Binding $parent[Window].DataContext.L[O3dNoMetadata]}" FontSize="11" FontStyle="Italic" Foreground="#64748b"/>
                                                        <TextBlock Text="{Binding $parent[Window].DataContext.L[O3dUnsupportedHeaderSuffix]}" FontSize="11" FontStyle="Italic" Foreground="#64748b" IsVisible="{Binding IsUnsupportedVersion}"/>
                                                    </StackPanel>
                                                    
                                                    <!-- Diagnostics (Errors/Warnings) -->
                                                    <StackPanel Margin="24,2,0,0" Spacing="3" IsVisible="{Binding HasMetadataDiagnostics}">
                                                        <Border Background="#2d1c1c" BorderBrush="#ef4444" BorderThickness="1" CornerRadius="4" Padding="10">
                                                            <StackPanel Spacing="4">
                                                                <TextBlock Text="{Binding $parent[Window].DataContext.L[O3dDiagnostics]}" FontSize="11" FontWeight="Bold" Foreground="#f87171"/>
                                                                <ItemsControl ItemsSource="{Binding MetadataDiagnostics}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock Text="{Binding Message}" FontSize="11" Foreground="#fca5a5" TextWrapping="Wrap" Margin="4,0,0,2"/>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding L[NoMeshes]}" 
                                           FontSize="13" 
                                           FontStyle="Italic" 
                                           Foreground="#64748b"
                                           IsVisible="{Binding SelectedAsset.HasNoMeshes}"/>
                            </StackPanel>
                        </Border>

                        <!-- Textures Section -->
                        <Border Background="#1a1a1e" BorderBrush="#2a2a32" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="{Binding L[TexturesSection]}" FontSize="14" FontWeight="SemiBold" Foreground="#6366f1"/>
                                <ItemsControl ItemsSource="{Binding SelectedAssetTextureReferences}" IsVisible="{Binding HasSelectedAssetTextureReferences}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#121214" BorderBrush="#2a2a32" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,6">
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <TextBlock Grid.Column="0" Text="🖼️" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                        <TextBlock Text="{Binding Path}" FontSize="13" Foreground="#e2e8f0"/>
                                                        <TextBlock Text="{Binding Source}" FontSize="11" Foreground="#64748b"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="{Binding L[NoTextures]}" 
                                           FontSize="13" 
                                           FontStyle="Italic" 
                                           Foreground="#64748b"
                                           IsVisible="{Binding HasNoSelectedAssetTextureReferences}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- 5. Default Selection prompt when assets are loaded but none selected -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8"
                            IsVisible="{Binding ShowNoSelectionPrompt}">
                    <TextBlock Text="{Binding L[NoSelectionTitle]}" FontSize="16" FontWeight="SemiBold" Foreground="#94a3b8" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding L[NoSelectionMessage]}" Foreground="#64748b" FontSize="13" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>

    <!-- Bottom Status Bar -->
    <Border Grid.Row="1" Background="#141416" BorderBrush="#2a2a32" BorderThickness="0,1,0,0" Padding="12,4">
        <Grid ColumnDefinitions="*,Auto">
            <!-- Left side: Root Directory Display -->
            <TextBlock Grid.Column="0" Text="{Binding RootDirectoryDisplay}" FontSize="11" Foreground="#64748b" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            
            <!-- Right side: Scan Progress and Cancel Button -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="{Binding ScanProgressText}" FontSize="11" Foreground="#94a3b8" VerticalAlignment="Center"/>
                <Button Content="{Binding L[CancelScan]}" 
                        Command="{Binding CancelScanCommand}" 
                        IsVisible="{Binding IsScanning}"
                        Background="#b91c1c" 
                        Foreground="White" 
                        CornerRadius="3" 
                        Padding="8,2"
                        FontSize="10"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Grid>
</Window>
